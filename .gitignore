# =============================================================================
# DATA SCIENCE PROJECT .gitignore
# Jupyter + Conda
# =============================================================================

# -----------------------------------------------------------------------------
# Data Files
# -----------------------------------------------------------------------------
*.csv
*.tsv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
data/raw/
data/processed/
data/interim/
data/external/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
*.ipynb_checkpoints

# Notebook outputs (optional — remove if you want to commit outputs)
# To strip outputs before committing, consider: nbstripout

# -----------------------------------------------------------------------------
# Conda Environment
# -----------------------------------------------------------------------------
envs/
.conda/
conda-meta/
*.conda
environment.lock.yml

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual environments (non-conda)
.env
.venv
env/
venv/
ENV/

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs & Debugging
# -----------------------------------------------------------------------------
*.log
logs/
*.out
*.err

# -----------------------------------------------------------------------------
# Model Artifacts (often large — store with DVC or similar)
# -----------------------------------------------------------------------------
models/
*.model
*.joblib
*.pt
*.pth
*.ckpt
*.pb

# -----------------------------------------------------------------------------
# Secrets & Credentials
# -----------------------------------------------------------------------------
.env
.env.*
secrets.yml
secrets.yaml
credentials.json
*.pem
*.key

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.cache/
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml